# Environment
ENVIRONMENT=production

# Django
SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Application
APP_PORT=8015
TIME_ZONE=America/Guayaquil

# Django database connection
# Fase 1 mantiene una sola base activa mediante DB_NAME.
DB_NAME=sistema_agua_master
DB_USER=sistema_agua_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_PUBLIC_PORT=5432

# Future multi-tenant database contract
MASTER_DB_NAME=sistema_agua_master
TENANT_DEFAULT=carabuela
TENANT_SLUGS=carabuela,esperanza,pesillo
TENANT_DB_PREFIX=sistema_agua_
TENANT_ADMIN_DB_NAME=postgres
TENANT_ROUTE_MODE=path

# Sessions
SESSION_COOKIE_AGE=3600
SESSION_COOKIE_NAME=sistema_agua_sessionid
CSRF_COOKIE_NAME=sistema_agua_csrftoken

# HTTPS/security headers
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_X_FORWARDED_HOST=False
SECURE_PROXY_SSL_HEADER_ENABLED=False

# Development helpers
ENABLE_DJANGO_EXTENSIONS=False

# Login brute-force protection
AXES_FAILURE_LIMIT=3
AXES_COOLOFF_TIME=0.25
